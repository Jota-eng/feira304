<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guia da Célula · Sicredi Natal v3</title>
<style>
:root {
  --verde: #1E8A50;
  --verde-dark: #0E5C35;
  --verde-darker: #092B1A;
  --verde-light: #2AAD64;
  --verde-muted: #4CAF7D;
  --verde-bg: #E8F5EE;
  --verde-bg2: #C8E6D4;
  --text: #0A1F14;
  --text2: #2D4A38;
  --text3: #5A7A66;
  --surface: #FFFFFF;
  --surface2: #F4FAF7;
  --surface3: #EAF4EF;
  --border: #C8E0D3;
  --border2: #DDEEE5;
  --sidebar-w: 232px;
  --header-h: 58px;
  --radius: 12px;
  --radius-sm: 8px;
  --shadow: 0 2px 10px rgba(14,92,53,0.07);
  --shadow-md: 0 4px 20px rgba(14,92,53,0.12);
  --gold: #E8A020;
  --gold-bg: #FEF7E8;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { font-family:"Segoe UI",system-ui,-apple-system,sans-serif; background:var(--surface2); color:var(--text); min-height:100vh; }

/* ── SIDEBAR ── */
.sidebar { position:fixed; top:0; left:0; width:var(--sidebar-w); height:100vh; background:var(--verde-darker); display:flex; flex-direction:column; z-index:100; transition:transform .25s; overflow-y:auto; }
.sidebar-logo { padding:18px 16px 14px; border-bottom:1px solid rgba(255,255,255,0.07); flex-shrink:0; }
.logo-row { display:flex; align-items:center; gap:10px; }
.logo-icon { width:34px; height:34px; background:var(--verde); border-radius:9px; display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0; }
.logo-title { font-size:14px; font-weight:700; color:#fff; line-height:1.2; }
.logo-sub { font-size:10px; color:rgba(255,255,255,0.38); text-transform:uppercase; letter-spacing:1px; margin-top:1px; }
.nav-group { padding:8px 0 4px; }
.nav-label { padding:5px 14px 2px; font-size:9px; font-weight:700; text-transform:uppercase; letter-spacing:1.2px; color:rgba(255,255,255,0.22); }
.nav-item { display:flex; align-items:center; gap:9px; padding:8px 14px; cursor:pointer; color:rgba(255,255,255,0.58); font-size:12.5px; font-weight:500; text-decoration:none; transition:all .15s; position:relative; border-left:2.5px solid transparent; }
.nav-item:hover { background:rgba(255,255,255,0.06); color:#fff; }
.nav-item.active { background:rgba(255,255,255,0.1); color:#fff; border-left-color:var(--verde-light); }
.nav-icon { font-size:14px; width:18px; text-align:center; flex-shrink:0; }
.sidebar-footer { padding:12px 14px; border-top:1px solid rgba(255,255,255,0.06); font-size:10px; color:rgba(255,255,255,0.25); margin-top:auto; flex-shrink:0; }

/* ── HEADER ── */
.header { position:fixed; top:0; left:var(--sidebar-w); right:0; height:var(--header-h); background:var(--surface); border-bottom:1px solid var(--border2); display:flex; align-items:center; padding:0 22px; gap:10px; z-index:99; box-shadow:0 1px 6px rgba(14,92,53,0.05); }
.hamburger { display:none; flex-direction:column; gap:4px; cursor:pointer; padding:4px; margin-right:4px; }
.hamburger span { width:18px; height:2px; background:var(--verde-dark); border-radius:2px; }
.header-title { font-size:14px; font-weight:700; color:var(--verde-dark); flex-shrink:0; }
.search-wrap { flex:1; max-width:360px; position:relative; }
.search-wrap svg { position:absolute; left:10px; top:50%; transform:translateY(-50%); color:var(--text3); pointer-events:none; }
#searchInput { width:100%; background:var(--surface2); border:1.5px solid var(--border); border-radius:9px; padding:7px 10px 7px 32px; font-family:inherit; font-size:12.5px; color:var(--text); outline:none; transition:border-color .2s; }
#searchInput:focus { border-color:var(--verde); }
#searchInput::placeholder { color:var(--text3); }
.header-right { margin-left:auto; display:flex; align-items:center; gap:10px; }
.header-date { font-size:11.5px; color:var(--text3); }
.overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.35); z-index:99; }
.overlay.show { display:block; }

/* ── MAIN ── */
.main { margin-left:var(--sidebar-w); margin-top:var(--header-h); padding:22px; min-height:calc(100vh - var(--header-h)); }
.section { display:none; animation:fadeUp .22s ease; }
.section.active { display:block; }
@keyframes fadeUp { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:translateY(0)} }

/* ── TYPOGRAPHY ── */
.page-title { font-size:21px; font-weight:800; color:var(--verde-dark); letter-spacing:-.3px; }
.page-sub { font-size:12.5px; color:var(--text3); margin-top:3px; margin-bottom:18px; }

/* ── GRID ── */
.grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:14px; }
.grid-3 { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.grid-4 { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }

/* ── CARD ── */
.card { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); box-shadow:var(--shadow); overflow:hidden; }
.card-head { padding:13px 16px; border-bottom:1px solid var(--border2); display:flex; align-items:center; gap:9px; }
.card-icon { width:34px; height:34px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:16px; flex-shrink:0; }
.card-title { font-size:13.5px; font-weight:700; color:var(--text); }
.card-body { padding:14px 16px; }

/* ── DASH CARDS ── */
.dash-card { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); padding:18px; cursor:pointer; transition:transform .15s,box-shadow .15s,border-color .15s; box-shadow:var(--shadow); display:flex; flex-direction:column; gap:9px; }
.dash-card:hover { transform:translateY(-2px); box-shadow:var(--shadow-md); border-color:var(--verde-muted); }
.dash-icon { width:42px; height:42px; border-radius:11px; display:flex; align-items:center; justify-content:center; font-size:19px; }
.dash-name { font-size:13.5px; font-weight:700; color:var(--text); }
.dash-desc { font-size:11.5px; color:var(--text3); line-height:1.5; }

/* ── TABS ── */
.tabs { display:flex; gap:2px; background:var(--surface3); border-radius:9px; padding:3px; margin-bottom:16px; width:fit-content; }
.tab-btn { padding:6px 18px; border-radius:7px; font-size:12.5px; font-weight:600; cursor:pointer; border:none; background:transparent; color:var(--text3); font-family:inherit; transition:all .15s; }
.tab-btn.active { background:var(--surface); color:var(--verde-dark); box-shadow:0 1px 5px rgba(14,92,53,0.1); }

/* ── CHIPS ── */
.chips { display:flex; flex-wrap:wrap; gap:4px; margin-top:5px; }
.chip { font-size:10px; font-weight:600; padding:2px 7px; border-radius:20px; background:var(--verde-bg); color:var(--verde-dark); border:1px solid var(--verde-bg2); }

/* ── PRODUTO CARD ── */
.produto-card { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); transition:box-shadow .15s; }
.produto-card:hover { box-shadow:var(--shadow-md); }
.produto-header { background:linear-gradient(135deg,var(--verde-dark),var(--verde)); padding:14px 16px; display:flex; align-items:center; justify-content:space-between; }
.produto-nome { font-size:14px; font-weight:700; color:#fff; }
.btn-spin { font-size:10.5px; font-weight:700; padding:4px 11px; border-radius:6px; border:1.5px solid rgba(255,255,255,0.35); background:rgba(255,255,255,0.1); color:#fff; cursor:pointer; font-family:inherit; transition:background .15s; flex-shrink:0; }
.btn-spin:hover { background:rgba(255,255,255,0.2); }
.produto-body { padding:13px 16px; }
.oferta-label { font-size:9.5px; font-weight:700; text-transform:uppercase; letter-spacing:.8px; color:var(--text3); margin-bottom:7px; }
.oferta-list { list-style:none; }
.oferta-list li { font-size:12.5px; color:var(--text2); padding:3px 0; display:flex; align-items:flex-start; gap:6px; border-bottom:1px solid var(--border2); }
.oferta-list li:last-child { border-bottom:none; }
.oferta-list li::before { content:'→'; color:var(--verde); font-weight:700; flex-shrink:0; }

/* ── PERFIL CARD ── */
.perfil-card { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); }
.perfil-header { padding:16px; border-bottom:1px solid var(--border2); }
.perfil-badge { display:inline-block; font-size:10.5px; font-weight:800; padding:3px 9px; border-radius:20px; margin-bottom:7px; }
.perfil-foco { font-size:12.5px; color:var(--text2); line-height:1.5; }
details { border-top:1px solid var(--border2); }
details summary { padding:10px 16px; font-size:11.5px; font-weight:700; color:var(--text2); cursor:pointer; list-style:none; display:flex; align-items:center; justify-content:space-between; user-select:none; transition:background .15s; }
details summary:hover { background:var(--surface2); }
details summary::after { content:'▼'; font-size:8px; color:var(--text3); transition:transform .2s; }
details[open] summary::after { transform:rotate(180deg); }
details .detail-body { padding:9px 16px 12px; background:var(--surface2); }
details .detail-body ul { list-style:none; }
details .detail-body ul li { font-size:12.5px; color:var(--text2); padding:3px 0; display:flex; align-items:flex-start; gap:7px; }
details .detail-body ul li::before { content:'•'; color:var(--verde); font-weight:900; flex-shrink:0; }

/* ── SPIN ── */
.spin-selects { display:flex; gap:10px; margin-bottom:18px; flex-wrap:wrap; }
.spin-selects select { background:var(--surface); border:1.5px solid var(--border); border-radius:8px; padding:8px 12px; font-family:inherit; font-size:12.5px; font-weight:600; color:var(--text); outline:none; cursor:pointer; transition:border-color .2s; min-width:170px; }
.spin-selects select:focus { border-color:var(--verde); }
.spin-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; }
.spin-col { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); }
.spin-col-header { padding:11px 13px; font-size:12.5px; font-weight:800; display:flex; align-items:center; gap:7px; }
.spin-letter { width:26px; height:26px; border-radius:7px; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center; font-size:13px; font-weight:900; }
.spin-col-body { padding:11px 13px; }
.spin-col-body ul { list-style:none; }
.spin-col-body ul li { font-size:11.5px; color:var(--text2); padding:4px 0; border-bottom:1px solid var(--border2); line-height:1.4; }
.spin-col-body ul li:last-child { border-bottom:none; }
.spin-s .spin-col-header { background:#1565C0; color:#fff; }
.spin-p .spin-col-header { background:#B03020; color:#fff; }
.spin-i .spin-col-header { background:#C07818; color:#fff; }
.spin-n .spin-col-header { background:#1E8A50; color:#fff; }

/* ── AGENDA ── */
.agenda-list { list-style:none; }
.agenda-item { display:flex; gap:12px; padding:11px 0; border-bottom:1px solid var(--border2); align-items:flex-start; }
.agenda-item:last-child { border-bottom:none; }
.agenda-time { font-size:11px; font-weight:800; color:var(--verde); white-space:nowrap; min-width:95px; padding-top:1px; }
.agenda-ouro { background:var(--gold-bg); border-radius:8px; padding:9px 12px; margin:2px 0; }
.agenda-ouro .agenda-time { color:var(--gold); }
.agenda-desc { font-size:12.5px; color:var(--text2); line-height:1.5; }
.ei-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.ei-card { border-radius:8px; overflow:hidden; border:1px solid var(--border2); }
.ei-head { padding:9px 13px; font-size:11.5px; font-weight:700; }
.ei-body { padding:9px 13px; background:var(--surface); }
.ei-body ul { list-style:none; }
.ei-body ul li { font-size:12px; color:var(--text2); padding:3px 0; display:flex; gap:6px; }
.ei-body ul li::before { content:'—'; color:var(--text3); flex-shrink:0; }
.ei-ui .ei-head { background:#FDECEC; color:#8B1A1A; }
.ei-inu .ei-head { background:#E8F5EE; color:#0E5C35; }
.ei-uni .ei-head { background:var(--gold-bg); color:#7A5000; }
.ei-nuni .ei-head { background:#F2F2F2; color:#555; }

/* ── PROSPECÇÃO ── */
.passos-list { list-style:none; }
.passo-item { display:flex; gap:12px; padding:10px 0; border-bottom:1px solid var(--border2); align-items:flex-start; }
.passo-item:last-child { border-bottom:none; }
.passo-num { width:24px; height:24px; border-radius:50%; background:var(--verde); color:#fff; font-size:11px; font-weight:800; display:flex; align-items:center; justify-content:center; flex-shrink:0; margin-top:1px; }
.passo-text { font-size:12.5px; color:var(--text2); line-height:1.5; }
.abertura-list { list-style:none; }
.abertura-item { background:var(--verde-bg); border:1px solid var(--verde-bg2); border-left:3px solid var(--verde); border-radius:7px; padding:11px 13px; font-size:12.5px; color:var(--text2); font-style:italic; margin-bottom:7px; line-height:1.5; }
.objecao-row { border:1px solid var(--border2); border-radius:8px; overflow:hidden; margin-bottom:7px; }
.objecao-q { padding:10px 13px; background:#FDF2F2; font-size:12.5px; font-weight:600; color:#8B1A1A; display:flex; align-items:center; gap:7px; }
.objecao-q::before { content:'⚠️'; font-size:13px; }
.objecao-a { padding:10px 13px; background:var(--surface); font-size:12.5px; color:var(--text2); display:flex; align-items:flex-start; gap:7px; line-height:1.5; }
.objecao-a::before { content:'💬'; font-size:13px; flex-shrink:0; }

/* ── BIBLIOTECA ── */
.bib-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:9px; }
.bib-card { display:flex; align-items:center; gap:11px; padding:12px 14px; background:var(--surface); border:1px solid var(--border2); border-radius:9px; text-decoration:none; transition:all .15s; box-shadow:var(--shadow); }
.bib-card:hover { border-color:var(--verde-muted); box-shadow:var(--shadow-md); transform:translateY(-1px); }
.bib-icon { width:36px; height:36px; border-radius:8px; display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0; }
.bib-name { font-size:12.5px; font-weight:600; color:var(--text); }
.bib-type { font-size:10.5px; color:var(--text3); margin-top:1px; }

/* ── COMO FUNCIONA ── */
.cf-hero { background:linear-gradient(135deg, var(--verde-darker) 0%, var(--verde-dark) 60%, var(--verde) 100%); border-radius:var(--radius); padding:28px 28px 24px; margin-bottom:18px; color:#fff; position:relative; overflow:hidden; }
.cf-hero::before { content:''; position:absolute; right:-30px; top:-30px; width:200px; height:200px; border-radius:50%; background:rgba(255,255,255,0.04); }
.cf-hero::after { content:''; position:absolute; right:40px; bottom:-40px; width:140px; height:140px; border-radius:50%; background:rgba(255,255,255,0.03); }
.cf-hero-tag { display:inline-block; font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:1px; background:rgba(255,255,255,0.15); padding:3px 10px; border-radius:20px; margin-bottom:10px; }
.cf-hero-title { font-size:22px; font-weight:800; letter-spacing:-.3px; margin-bottom:6px; }
.cf-hero-sub { font-size:13px; opacity:.75; line-height:1.6; max-width:560px; }
.cf-hero-stats { display:flex; gap:24px; margin-top:20px; flex-wrap:wrap; }
.cf-stat { text-align:center; }
.cf-stat-num { font-size:24px; font-weight:800; line-height:1; }
.cf-stat-label { font-size:10px; opacity:.6; text-transform:uppercase; letter-spacing:.5px; margin-top:3px; }

.cf-section { margin-bottom:18px; }
.cf-section-title { font-size:13px; font-weight:800; color:var(--verde-dark); text-transform:uppercase; letter-spacing:.6px; margin-bottom:10px; display:flex; align-items:center; gap:7px; }
.cf-section-title::after { content:''; flex:1; height:1px; background:var(--border2); }

.flow-steps { display:flex; gap:0; position:relative; }
.flow-step { flex:1; text-align:center; position:relative; }
.flow-step:not(:last-child)::after { content:'→'; position:absolute; right:-12px; top:18px; color:var(--verde-muted); font-size:16px; font-weight:700; z-index:1; }
.flow-icon { width:40px; height:40px; border-radius:10px; background:var(--verde-bg); border:1.5px solid var(--verde-bg2); display:flex; align-items:center; justify-content:center; font-size:18px; margin:0 auto 7px; }
.flow-label { font-size:11px; font-weight:700; color:var(--text2); }
.flow-sub { font-size:10.5px; color:var(--text3); margin-top:2px; line-height:1.4; }

.ferr-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; }
.ferr-card { background:var(--surface); border:1px solid var(--border2); border-radius:9px; padding:13px 14px; }
.ferr-header { display:flex; align-items:center; gap:8px; margin-bottom:8px; }
.ferr-icon { font-size:18px; }
.ferr-name { font-size:13px; font-weight:700; color:var(--text); }
.ferr-desc { font-size:12px; color:var(--text3); line-height:1.5; }
.ferr-tag { display:inline-block; font-size:10px; font-weight:600; padding:2px 7px; border-radius:20px; margin-top:6px; background:var(--verde-bg); color:var(--verde-dark); border:1px solid var(--verde-bg2); }

.meta-cards { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; }
.meta-card { background:var(--surface); border:1px solid var(--border2); border-radius:9px; padding:14px; text-align:center; }
.meta-num { font-size:26px; font-weight:800; color:var(--verde-dark); line-height:1; }
.meta-label { font-size:11px; color:var(--text3); margin-top:4px; line-height:1.4; }
.meta-badge { display:inline-block; font-size:9.5px; font-weight:700; padding:2px 7px; border-radius:20px; margin-top:5px; }

.perfil-row { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-top:2px; }
.prow-card { background:var(--surface); border:1px solid var(--border2); border-radius:9px; padding:12px 13px; }
.prow-badge { font-size:10px; font-weight:800; padding:2px 8px; border-radius:20px; display:inline-block; margin-bottom:6px; }
.prow-title { font-size:12.5px; font-weight:700; color:var(--text); margin-bottom:4px; }
.prow-desc { font-size:11.5px; color:var(--text3); line-height:1.5; }

/* ── MISSÕES ── */
.missao-form { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); padding:18px; margin-bottom:18px; box-shadow:var(--shadow); }
.missao-form-title { font-size:14px; font-weight:700; color:var(--verde-dark); margin-bottom:14px; display:flex; align-items:center; gap:7px; }
.form-grid { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-bottom:10px; }
.form-field { display:flex; flex-direction:column; gap:4px; }
.form-field.full { grid-column:1/-1; }
.form-label { font-size:11px; font-weight:700; color:var(--text3); text-transform:uppercase; letter-spacing:.5px; }
.form-input, .form-textarea, .form-select { background:var(--surface2); border:1.5px solid var(--border); border-radius:8px; padding:8px 11px; font-family:inherit; font-size:12.5px; color:var(--text); outline:none; transition:border-color .2s; }
.form-input:focus, .form-textarea:focus, .form-select:focus { border-color:var(--verde); background:var(--surface); }
.form-textarea { resize:vertical; min-height:80px; line-height:1.5; }
.form-select { cursor:pointer; }
.form-actions { display:flex; gap:8px; margin-top:12px; }

.missoes-lista { display:flex; flex-direction:column; gap:12px; }
.missao-card { background:var(--surface); border:1px solid var(--border2); border-radius:var(--radius); overflow:hidden; box-shadow:var(--shadow); }
.missao-card-head { background:linear-gradient(135deg, var(--verde-darker), var(--verde-dark)); padding:13px 16px; display:flex; align-items:center; justify-content:space-between; }
.missao-card-title { font-size:14px; font-weight:700; color:#fff; }
.missao-card-meta { font-size:11px; color:rgba(255,255,255,.55); margin-top:2px; }
.missao-card-body { padding:14px 16px; }
.missao-section { margin-bottom:12px; }
.missao-section:last-child { margin-bottom:0; }
.missao-section-label { font-size:10px; font-weight:700; text-transform:uppercase; letter-spacing:.7px; color:var(--text3); margin-bottom:5px; }
.missao-section-text { font-size:12.5px; color:var(--text2); line-height:1.6; white-space:pre-wrap; }
.missao-tags { display:flex; flex-wrap:wrap; 
